package tower.concurrency;

import "github.com/archmage/chronomancy";

public class SummoningRitual {
    public static void main(String[] args) {
        System.out.println("Beginning ritual...");
        
        System.out.println("Drawing circle...");
        ManaPtr m = Mana.allocate(5);
        System.out.println("Circle complete. Mana consumed.");
        Mana.free(m);
        
        System.out.println("Ritual main thread continuing...");
    }
}
